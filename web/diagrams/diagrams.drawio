        <mxCell id="mmrgZ31232cfRxLB8HJS-25" value="&lt;div style=&quot;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Entra com os parâmetros de simulação&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;- Gera uma matriz X de n (tempo) linhas e m (dados) colunas.&amp;nbsp;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;- Os dados são respectivamente, distância, angulo relativo ao centro do radar, velocidade relativa ao radar, isso para cada alvo em sequencia.&amp;nbsp;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;- O n (tempo) tem passo de dt, sendo muito maior que o intervalo de um pulso.&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;br&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="360" y="410" width="120" height="380" as="geometry" />
        </mxCell>
        <mxCell id="mmrgZ31232cfRxLB8HJS-26" value="&lt;div style=&quot;&quot;&gt;Recebe a matriz de simulação.&amp;nbsp;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;- seleciona um intervalo de t0 a t1 (menor que o de simulação) e fs, e faz superamostragem.&amp;nbsp;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;br&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="560" y="410" width="120" height="130" as="geometry" />
        </mxCell>
        <mxCell id="mmrgZ31232cfRxLB8HJS-27" value="&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;PULSE GENERATION&lt;/span&gt;&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="760" y="180" width="120" height="80" as="geometry" />
        </mxCell>
        <mxCell id="mmrgZ31232cfRxLB8HJS-28" value="" style="endArrow=classic;html=1;rounded=0;exitX=0.5;exitY=0;exitDx=0;exitDy=0;entryX=0.5;entryY=1;entryDx=0;entryDy=0;" edge="1" parent="1" source="mmrgZ31232cfRxLB8HJS-13" target="mmrgZ31232cfRxLB8HJS-27">
